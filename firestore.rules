rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check roles
    function hasRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Community Needs: Public can report (create), only NGOs can update/view details
    match /community_needs/{needId} {
      allow create: if true; // Open reporting
      allow read, update: if hasRole('ngo') || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    // Volunteers: Volunteers can manage their own profile, NGOs can view for matching
    match /volunteers/{userId} {
      allow read: if hasRole('ngo') || hasRole('admin') || request.auth.uid == userId;
      allow write: if request.auth.uid == userId || hasRole('admin');
    }

    // Tasks: Only NGOs and Admins
    match /tasks/{taskId} {
      allow read, write: if hasRole('ngo') || hasRole('admin');
    }

    // Matches: Only involved volunteer and NGOs
    match /matches/{matchId} {
      allow read: if hasRole('ngo') || hasRole('admin') || request.auth.uid == resource.data.volunteerId;
      allow update: if request.auth.uid == resource.data.volunteerId || hasRole('ngo');
    }

    // Analytics: Read-only for Dashboard
    match /analytics_cache/{docId} {
      allow read: if hasRole('ngo') || hasRole('admin');
      allow write: if false; // Only updated via Cloud Functions
    }
  }
}
