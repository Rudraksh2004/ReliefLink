# Set default behavior to automatically normalize line endings:
* text=auto

# Force LF for text-based files:
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.graphql text eol=lf
*.svg text eol=lf

# Explicitly mark binary files to prevent normalization:
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Handle special files:
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE text eol=lf
