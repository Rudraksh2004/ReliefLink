# Handle line endings automatically for files detected as text 
# and leave binary files untouched
* text=auto

# Standardize on LF for all text files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.py text eol=lf
*.csv text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.svg text
*.ttf binary
*.woff binary
*.woff2 binary

# Ensure linguist detects languages correctly
*.tsx linguist-language=tsx
*.ts linguist-language=typescript
*.py linguist-language=python
